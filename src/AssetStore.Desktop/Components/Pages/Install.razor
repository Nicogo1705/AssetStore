@page "/projects/install"
@implements IDisposable
@inject CatalogState State
@inject DesktopInstaller Installer
@inject ProjectStore Store

@if (Asset is null)
{
    <a class="back" href="">← Back</a>
    <p class="notice">@(string.IsNullOrEmpty(Id) ? "No asset specified." : $"Asset '{Id}' not found.")</p>
}
else
{
    <PageTitle>Install @Asset.Manifest.Name</PageTitle>
    <a class="back" href="@($"asset?id={Uri.EscapeDataString(Asset.Id)}")">← Back to @Asset.Manifest.Name</a>
    <h1 style="margin:.2rem 0 1rem">Install @Asset.Manifest.Name</h1>

    @if (Asset.Manifest.Nuget is not null)
    {
        <section class="panel">
            <h2>Import mode</h2>
            <div class="modes" role="tablist">
                <button class="mode @(IsNuget ? "" : "active")" role="tab" @onclick='() => SetImport("local")'>Source &amp; ProjectReference</button>
                <button class="mode @(IsNuget ? "active" : "")" role="tab" @onclick='() => SetImport("nuget")'>NuGet package</button>
            </div>
            <p class="mode-desc">
                @(IsNuget
                    ? "Adds a <PackageReference> to the published package — no source is cloned."
                    : "Clones the source and adds a <ProjectReference> — you can compile and tweak it locally.")
            </p>
        </section>
    }

    @if (IsNuget)
    {
        <section class="panel">
            <p class="install-hint">NuGet install — adds <span class="mono">&lt;PackageReference Include="@Asset.Manifest.Nuget!.PackageId"@(Asset.Manifest.Nuget.PackageVersion is { } pv ? $" Version=\"{pv}\"" : "") /&gt;</span> to the projects you pick. No source is cloned.</p>
        </section>
    }
    else
    {
        <section class="panel">
            <h2>Version</h2>
            <label class="field">
                <select class="ipt" @bind="_ref">
                    <option value="@Asset.Latest.Ref">latest — @Asset.Latest.Ref branch (rolling)</option>
                    @foreach (var v in Asset.Versions)
                    {
                        <option value="@v.Tag">@v.Version — tag@(IsCertified(v.Commit) ? " ✓ certified" : "")</option>
                    }
                </select>
            </label>
            <p class="install-hint">
                @if (_ref == Asset.Latest.Ref)
                {
                    <text>Rolling <strong>@Asset.Latest.Ref</strong> — newest commit, not certified.</text>
                }
                else if (IsCertified(Asset.Versions.FirstOrDefault(v => v.Tag == _ref)?.Commit ?? ""))
                {
                    <text>✓ Certified release — reviewed &amp; pinned to an immutable commit.</text>
                }
                else
                {
                    <text>Tag <strong>@_ref</strong> — pinned, not certified.</text>
                }
            </p>
        </section>
    }

    <section class="panel">
        <h2>Choose a project</h2>
        @if (_tracked.Count > 0)
        {
            <p class="install-hint">Your tracked projects (managed in <a href="projects">My projects</a>):</p>
            <div class="pick-list">
                @foreach (var t in _tracked)
                {
                    var path = t.Path;
                    <button class="pick-row @(string.Equals(path, _picked, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                            @onclick="() => PickPath(path)" disabled="@(!t.Exists)">
                        <span class="mp-ico">@(t.IsSolution ? "🧩" : "📄")</span>
                        <span class="pick-name">@t.Name</span>
                        @if (!t.Exists)
                        {
                            <span class="badge" style="color:var(--warn);border-color:var(--warn)">missing</span>
                        }
                        <span class="install-hint pick-path">@path</span>
                    </button>
                }
            </div>
        }
        else
        {
            <p class="install-hint">No tracked projects yet — browse for one below and it'll be remembered in <a href="projects">My projects</a>.</p>
        }

        @if (_browsing || _tracked.Count == 0)
        {
            <p class="install-hint" style="margin-top:.6rem">Browse for a <span class="mono">.sln</span>/<span class="mono">.slnx</span>/<span class="mono">.csproj</span> — it's added to My projects automatically:</p>
            <FileBrowser FilesSelectable="true" StorageKey="assetstore.install.dir" OnFilePicked="OnPicked" />
        }
        else
        {
            <button class="btn" style="margin-top:.6rem" @onclick="() => _browsing = true">＋ Browse for another project…</button>
        }
    </section>

    @if (_picked is not null && _targets.Count == 0)
    {
        <section class="panel">
            <p class="notice">No C# projects found in that file. Pick a <span class="mono">.sln</span>/<span class="mono">.slnx</span> or a <span class="mono">.csproj</span>.</p>
        </section>
    }

    @if (_targets.Count > 0)
    {
        <section class="panel">
            <h2>Target projects</h2>
            <p class="install-hint"><span class="mono">@_picked</span></p>
            @if (!IsNuget)
            {
                <div class="cache-note">⚠ Installing clones third-party source and adds it to your build. Building the project will run its code — only install assets you trust.</div>
            }
            @foreach (var p in _targets)
            {
                <label class="check">
                    <input type="checkbox" checked="@_checked.Contains(p.Path)"
                           @onchange="e => Toggle(p.Path, (bool)e.Value!)" />
                    @p.Name <span class="install-hint">@p.Path</span>
                </label>
            }

            @if (!IsNuget)
            {
                <div class="clone-modes">
                    <div class="install-hint" style="margin-bottom:.35rem">Where to put the asset's source:</div>
                    <label class="check">
                        <input type="radio" name="clonemode" checked="@(_cloneMode == CloneMode.Shared)"
                               @onchange="() => SetCloneMode(CloneMode.Shared)" />
                        <span>Shared assets folder <span class="install-hint">— one place for all assets; projects reference it (reusable across projects).</span></span>
                    </label>
                    @if (_cloneMode == CloneMode.Shared)
                    {
                        <p class="mono install-hint" style="margin:.15rem 0 .5rem 1.7rem">@_cloneDir</p>
                    }
                    <label class="check">
                        <input type="radio" name="clonemode" checked="@(_cloneMode == CloneMode.Custom)"
                               @onchange="() => SetCloneMode(CloneMode.Custom)" />
                        <span>Choose a folder <span class="install-hint">— pick exactly where to clone (e.g. inside one project).</span></span>
                    </label>
                    @if (_cloneMode == CloneMode.Custom)
                    {
                        <div class="cmd" style="margin:.15rem 0 0 1.7rem">
                            <input class="ipt" style="flex:1" @bind="_cloneDir" />
                            <button class="btn" @onclick="() => _browsingClone = true">Browse…</button>
                        </div>
                    }
                </div>
            }

            <button class="btn primary" style="margin-top:.8rem" @onclick="DoInstall" disabled="@(_busy || _checked.Count == 0)">
                @(_busy ? "Installing…" : IsNuget ? $"Add package to {_checked.Count} project(s)" : $"Install into {_checked.Count} project(s)")
            </button>
        </section>
    }

    @if (_result is not null)
    {
        <section class="panel">
            <h2>@(_result.Success ? "✓ Done" : "✗ Failed")</h2>
            <ul class="problems" style="color:var(--text)">
                @foreach (var m in _result.Messages)
                {
                    <li>@m</li>
                }
            </ul>
        </section>
    }

    <Modal Visible="_browsingClone" Title="Choose a folder to clone into" Size="wide" OnClose="() => _browsingClone = false">
        <p class="install-hint" style="margin-top:0">The asset (and its dependencies) will be cloned into the folder shown below.</p>
        <FileBrowser FilesSelectable="false" StorageKey="assetstore.clonedir" OnDirChanged="OnCloneDirChanged" />
        <p class="mono install-hint">@_cloneDir</p>
        <div class="modal-foot">
            <button class="btn primary" @onclick="() => _browsingClone = false">Use this folder</button>
        </div>
    </Modal>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public string? Id { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }

    private enum CloneMode { Shared, Custom }

    private string _importMode = "local"; // "local" | "nuget" — switchable when the asset publishes a package
    private CloneMode _cloneMode = CloneMode.Shared;
    private string _ref = "main";
    private string? _picked;
    private string _sharedDir = "";
    private string _cloneDir = "";
    private bool _busy;
    private bool _browsing;
    private bool _browsingClone;
    private IReadOnlyList<TrackedProject> _tracked = [];
    private List<SolutionProject> _targets = [];
    private readonly HashSet<string> _checked = new(StringComparer.OrdinalIgnoreCase);
    private InstallResult? _result;

    private IndexedAsset? Asset => string.IsNullOrEmpty(Id) ? null : State.Find(Id);

    private bool IsNuget =>
        string.Equals(_importMode, "nuget", StringComparison.OrdinalIgnoreCase) && Asset?.Manifest.Nuget is not null;

    private bool IsCertified(string commit) =>
        Asset is not null && !string.IsNullOrEmpty(commit)
        && Asset.Certified.Any(c => string.Equals(c.Commit, commit, StringComparison.Ordinal));

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        await State.EnsureLoadedAsync();
        _ref = Asset?.Latest.Ref ?? "main";
        _tracked = Store.List();
    }

    protected override void OnParametersSet()
    {
        if (Asset is not null)
        {
            _ref = Asset.Latest.Ref;
        }

        // Seed the import mode from the query (?mode=), but the user can switch it below.
        _importMode = string.Equals(Mode, "nuget", StringComparison.OrdinalIgnoreCase) && Asset?.Manifest.Nuget is not null
            ? "nuget"
            : "local";

        _picked = null;
        _targets = [];
        _checked.Clear();
        _result = null;
    }

    private void SetImport(string mode)
    {
        _importMode = mode;
        _result = null;
    }

    private void SetCloneMode(CloneMode mode)
    {
        _cloneMode = mode;
        if (mode == CloneMode.Shared)
        {
            _cloneDir = _sharedDir;
        }
    }

    private void OnCloneDirChanged(string? dir)
    {
        if (!string.IsNullOrEmpty(dir))
        {
            _cloneDir = dir;
        }
    }

    // A project picked from the file browser is remembered in My projects, so both entry points
    // (browse once vs. pick a tracked project) converge on the same list afterwards.
    private void OnPicked(FsEntry e)
    {
        Store.Add(e.Path);
        _tracked = Store.List();
        _browsing = false;
        PickPath(e.Path);
    }

    // Single code path for choosing a target, whether from a tracked project or the browser.
    private void PickPath(string path)
    {
        _picked = path;
        _sharedDir = Path.Combine(Path.GetDirectoryName(path)!, "StoreAssets");
        if (_cloneMode == CloneMode.Shared)
        {
            _cloneDir = _sharedDir;
        }

        try
        {
            _targets = Installer.ReadTargets(path).ToList();
        }
        catch
        {
            _targets = [];
        }

        _checked.Clear(); // let the user choose which projects to add the reference to
    }

    private void Toggle(string path, bool on)
    {
        if (on) _checked.Add(path); else _checked.Remove(path);
    }

    private async Task DoInstall()
    {
        _busy = true;
        _result = null;
        var asset = Asset!;
        var reference = _ref;
        var targets = _checked.ToList();
        var cloneDir = _cloneDir;
        var nuget = IsNuget;
        var catalog = State.Catalog!.Assets.ToDictionary(a => a.Id, StringComparer.Ordinal);
        // Run the blocking git/IO work off the render thread so the "Installing…" state shows.
        _result = await Task.Run(() => nuget
            ? Installer.InstallNuget(asset, targets)
            : Installer.Install(asset, reference, targets, catalog, cloneDir));
        _busy = false;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnChanged;
}
