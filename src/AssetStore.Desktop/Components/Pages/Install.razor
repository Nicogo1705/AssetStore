@page "/install"
@implements IDisposable
@inject CatalogState State
@inject DesktopInstaller Installer

@if (Asset is null)
{
    <a class="back" href="">← Back</a>
    <p class="notice">@(string.IsNullOrEmpty(Id) ? "No asset specified." : $"Asset '{Id}' not found.")</p>
}
else
{
    <PageTitle>Install @Asset.Manifest.Name</PageTitle>
    <a class="back" href="@($"asset?id={Uri.EscapeDataString(Asset.Id)}")">← Back to @Asset.Manifest.Name</a>
    <h1 style="margin:.2rem 0 1rem">Install @Asset.Manifest.Name</h1>

    @if (IsNuget)
    {
        <section class="panel">
            <p class="install-hint">NuGet install — adds <span class="mono">&lt;PackageReference Include="@Asset.Manifest.Nuget!.PackageId"@(Asset.Manifest.Nuget.PackageVersion is { } pv ? $" Version=\"{pv}\"" : "") /&gt;</span> to the projects you pick. No source is cloned.</p>
        </section>
    }
    else
    {
        <section class="panel">
            <h2>Version</h2>
            <label class="field">
                <select class="ipt" @bind="_ref">
                    <option value="@Asset.Latest.Ref">latest — @Asset.Latest.Ref branch (rolling)</option>
                    @foreach (var v in Asset.Versions)
                    {
                        <option value="@v.Tag">@v.Version — tag@(IsCertified(v.Commit) ? " ✓ certified" : "")</option>
                    }
                </select>
            </label>
            <p class="install-hint">
                @if (_ref == Asset.Latest.Ref)
                {
                    <text>Rolling <strong>@Asset.Latest.Ref</strong> — newest commit, not certified.</text>
                }
                else if (IsCertified(Asset.Versions.FirstOrDefault(v => v.Tag == _ref)?.Commit ?? ""))
                {
                    <text>✓ Certified release — reviewed &amp; pinned to an immutable commit.</text>
                }
                else
                {
                    <text>Tag <strong>@_ref</strong> — pinned, not certified.</text>
                }
            </p>
        </section>
    }

    <section class="panel">
        <h2>Pick a solution or project</h2>
        <FileBrowser FilesSelectable="true" StorageKey="assetstore.install.dir" OnFilePicked="OnPicked" />
    </section>

    @if (_picked is not null && _targets.Count == 0)
    {
        <section class="panel">
            <p class="notice">No C# projects found in that file. Pick a <span class="mono">.sln</span>/<span class="mono">.slnx</span> or a <span class="mono">.csproj</span>.</p>
        </section>
    }

    @if (_targets.Count > 0)
    {
        <section class="panel">
            <h2>Target projects</h2>
            <p class="install-hint"><span class="mono">@_picked</span></p>
            @if (!IsNuget)
            {
                <div class="cache-note">⚠ Installing clones third-party source and adds it to your build. Building the project will run its code — only install assets you trust.</div>
            }
            @foreach (var p in _targets)
            {
                <label class="check">
                    <input type="checkbox" checked="@_checked.Contains(p.Path)"
                           @onchange="e => Toggle(p.Path, (bool)e.Value!)" />
                    @p.Name <span class="install-hint">@p.Path</span>
                </label>
            }

            @if (!IsNuget)
            {
                <label class="field" style="margin:.8rem 0 .2rem">Clone assets into
                    <input class="ipt" style="flex:1;min-width:420px" @bind="_cloneDir" />
                </label>
            }

            <button class="btn primary" style="margin-top:.6rem" @onclick="DoInstall" disabled="@(_busy || _checked.Count == 0)">
                @(_busy ? "Installing…" : IsNuget ? $"Add package to {_checked.Count} project(s)" : $"Install into {_checked.Count} project(s)")
            </button>
        </section>
    }

    @if (_result is not null)
    {
        <section class="panel">
            <h2>@(_result.Success ? "✓ Done" : "✗ Failed")</h2>
            <ul class="problems" style="color:var(--text)">
                @foreach (var m in _result.Messages)
                {
                    <li>@m</li>
                }
            </ul>
        </section>
    }
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public string? Id { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }

    private bool IsNuget =>
        string.Equals(Mode, "nuget", StringComparison.OrdinalIgnoreCase) && Asset?.Manifest.Nuget is not null;

    private string _ref = "main";
    private string? _picked;
    private string _cloneDir = "";
    private bool _busy;
    private List<SolutionProject> _targets = [];
    private readonly HashSet<string> _checked = new(StringComparer.OrdinalIgnoreCase);
    private InstallResult? _result;

    private IndexedAsset? Asset => string.IsNullOrEmpty(Id) ? null : State.Find(Id);

    private bool IsCertified(string commit) =>
        Asset is not null && !string.IsNullOrEmpty(commit)
        && Asset.Certified.Any(c => string.Equals(c.Commit, commit, StringComparison.Ordinal));

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        await State.EnsureLoadedAsync();
        _ref = Asset?.Latest.Ref ?? "main";
    }

    protected override void OnParametersSet()
    {
        // Reset per-asset selections when navigating between assets (the component is reused).
        if (Asset is not null)
        {
            _ref = Asset.Latest.Ref;
        }

        _picked = null;
        _targets = [];
        _checked.Clear();
        _result = null;
    }

    private void OnPicked(FsEntry e)
    {
        _picked = e.Path;
        _cloneDir = Path.Combine(Path.GetDirectoryName(e.Path)!, "StoreAssets");
        _targets = Installer.ReadTargets(e.Path).ToList();
        _checked.Clear(); // let the user choose which projects to add the reference to
    }

    private void Toggle(string path, bool on)
    {
        if (on) _checked.Add(path); else _checked.Remove(path);
    }

    private async Task DoInstall()
    {
        _busy = true;
        _result = null;
        var asset = Asset!;
        var reference = _ref;
        var targets = _checked.ToList();
        var cloneDir = _cloneDir;
        var nuget = IsNuget;
        var catalog = State.Catalog!.Assets.ToDictionary(a => a.Id, StringComparer.Ordinal);
        // Run the blocking git/IO work off the render thread so the "Installing…" state shows.
        _result = await Task.Run(() => nuget
            ? Installer.InstallNuget(asset, targets)
            : Installer.Install(asset, reference, targets, catalog, cloneDir));
        _busy = false;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.Changed -= OnChanged;
}
