@inject DesktopInstaller Installer
@inject IJSRuntime JS

<div class="fb">
    <div class="fb-path">
        <button class="btn" title="Up one level" @onclick="GoUp" disabled="@(_dir is null)">↑</button>
        <input class="ipt" list="fb-suggest" value="@_input" @oninput="OnInput" @onkeydown="OnKey"
               placeholder="Type or paste a folder path (it follows you as you type / or \)" />
        <datalist id="fb-suggest">
            @foreach (var s in Suggestions())
            {
                <option value="@s" />
            }
        </datalist>
        <button class="btn" @onclick="GoTyped">Go</button>
    </div>
    <p class="install-hint" style="margin:.3rem 0">@(_dir ?? "(drives)")</p>
    <div class="fs">
        @foreach (var e in Displayed())
        {
            <button class="fs-row @(e.Kind != FsKind.Directory ? "file" : "")" @onclick="() => OnEntry(e)">
                <span class="fs-ico">@Icon(e.Kind)</span> @e.Name
            </button>
        }
    </div>
</div>

@code {
    /// <summary>When true, .sln/.slnx/.csproj files are listed and selectable; otherwise folders only.</summary>
    [Parameter] public bool FilesSelectable { get; set; }

    /// <summary>When true (with <see cref="FilesSelectable"/>), only .sln/.slnx are shown — no .csproj.</summary>
    [Parameter] public bool SolutionsOnly { get; set; }

    [Parameter] public string StorageKey { get; set; } = "assetstore.lastdir";

    /// <summary>Raised whenever the current directory changes (and once on load).</summary>
    [Parameter] public EventCallback<string?> OnDirChanged { get; set; }

    /// <summary>Raised when a file is selected (only when <see cref="FilesSelectable"/>).</summary>
    [Parameter] public EventCallback<FsEntry> OnFilePicked { get; set; }

    private string? _dir;
    private string _input = "";
    private IReadOnlyList<FsEntry> _entries = [];

    protected override void OnInitialized()
    {
        _dir = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        Load();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var saved = await Get();
        if (!string.IsNullOrEmpty(saved) && Directory.Exists(saved) && saved != _dir)
        {
            _dir = saved;
            Load();
            StateHasChanged();
        }

        await OnDirChanged.InvokeAsync(_dir);
    }

    private void Load()
    {
        _input = _dir ?? "";
        var all = Installer.Browse(_dir);
        _entries = !FilesSelectable
            ? all.Where(e => e.Kind == FsKind.Directory).ToList()
            : SolutionsOnly
                ? all.Where(e => e.Kind is FsKind.Directory or FsKind.Solution).ToList()
                : all;
    }

    private async Task Navigate(string? dir)
    {
        _dir = dir;
        Load();
        await Save();
        await OnDirChanged.InvokeAsync(_dir);
    }

    private async Task OnEntry(FsEntry e)
    {
        if (e.Kind == FsKind.Directory)
        {
            await Navigate(e.Path);
        }
        else
        {
            await OnFilePicked.InvokeAsync(e);
        }
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? "";

        // Live navigation: as soon as a separator is typed, dive into that folder so the list updates.
        if (_input.Length > 0 && (_input[^1] == '/' || _input[^1] == '\\'))
        {
            var sep = _input[^1];
            var dir = _input.TrimEnd('/', '\\');
            if (dir.Length == 2 && dir[1] == ':')
            {
                dir += Path.DirectorySeparatorChar;
            }

            if (!string.IsNullOrEmpty(dir) && Directory.Exists(dir) && !SamePath(dir, _dir))
            {
                _dir = dir;
                Load();
                _input = dir.EndsWith(sep) ? dir : dir + sep; // keep what the user is typing
                await Save();
                await OnDirChanged.InvokeAsync(_dir);
            }
        }
    }

    private static bool SamePath(string a, string? b) =>
        string.Equals(a.TrimEnd('/', '\\'), (b ?? "").TrimEnd('/', '\\'), StringComparison.OrdinalIgnoreCase);

    private async Task GoUp()
    {
        if (_dir is not null)
        {
            await Navigate(Directory.GetParent(_dir)?.FullName);
        }
    }

    /// <summary>The segment being typed after the current directory (no further separators), or "".</summary>
    private string CurrentPartial()
    {
        if (_dir is null || string.IsNullOrEmpty(_input))
        {
            return "";
        }

        var d = _dir.TrimEnd('/', '\\');
        if (_input.Length <= d.Length || !_input.StartsWith(d, StringComparison.OrdinalIgnoreCase))
        {
            return "";
        }

        var rest = _input[d.Length..].TrimStart('/', '\\');
        return rest.IndexOfAny(['/', '\\']) < 0 ? rest : "";
    }

    /// <summary>Folder entries filtered by what's currently being typed (".." always kept).</summary>
    private IEnumerable<FsEntry> Displayed()
    {
        var partial = CurrentPartial();
        return string.IsNullOrEmpty(partial)
            ? _entries
            : _entries.Where(e => e.Name == ".." || e.Name.StartsWith(partial, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>Folder-path completions for what's currently typed, preserving the exact separators typed.</summary>
    private IEnumerable<string> Suggestions()
    {
        if (string.IsNullOrWhiteSpace(_input))
        {
            return [];
        }

        try
        {
            var lastSep = _input.LastIndexOfAny(['/', '\\']);
            if (lastSep < 0)
            {
                return [];
            }

            var prefix = _input[..(lastSep + 1)]; // verbatim — keeps the user's separators so the datalist matches
            var partial = _input[(lastSep + 1)..];
            var parent = _input[..lastSep];
            if (parent.Length == 2 && parent[1] == ':')
            {
                parent += Path.DirectorySeparatorChar; // drive root, e.g. "C:" -> "C:\"
            }

            if (string.IsNullOrEmpty(parent) || !Directory.Exists(parent))
            {
                return [];
            }

            return Directory.GetDirectories(parent)
                .Select(Path.GetFileName)
                .Where(n => !string.IsNullOrEmpty(n) && n.StartsWith(partial, StringComparison.OrdinalIgnoreCase))
                .Select(n => prefix + n)
                .Take(25)
                .ToList();
        }
        catch
        {
            return [];
        }
    }

    private async Task GoTyped()
    {
        if (!string.IsNullOrWhiteSpace(_input) && Directory.Exists(_input))
        {
            await Navigate(Path.GetFullPath(_input));
        }
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GoTyped();
        }
    }

    private async Task Save()
    {
        try { await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, _dir ?? ""); } catch { }
    }

    private async Task<string?> Get()
    {
        try { return await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey); } catch { return null; }
    }

    private static string Icon(FsKind k) => k switch
    {
        FsKind.Solution => "🧩",
        FsKind.Project => "📄",
        _ => "📁",
    };
}
