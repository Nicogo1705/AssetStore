<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Stride Asset Store</title>
    <link rel="stylesheet" href="_content/AssetStore.UI/app.css" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    <div id="components-reconnect-modal" class="reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-spinner"></div>
            <div class="reconnect-title">Reconnecting…</div>
            <div class="reconnect-sub">The Stride Asset Store lost its connection — retrying.</div>
        </div>
    </div>

    <script src="_content/AssetStore.UI/js/interop.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
