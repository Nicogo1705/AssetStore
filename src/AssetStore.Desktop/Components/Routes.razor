<Router AppAssembly="typeof(Routes).Assembly" AdditionalAssemblies="_uiAssembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(AssetStore.App.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(AssetStore.App.Layout.MainLayout)">
            <a class="back" href="">← Back to catalog</a>
            <h1 style="margin:.2rem 0 1rem">Page not found</h1>
            <p class="install-hint">That page doesn't exist. It may have been moved, or the link is wrong.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    // Routable pages (Home, AssetDetail, Publish) live in the shared AssetStore.UI RCL.
    private readonly System.Reflection.Assembly[] _uiAssembly =
        [typeof(AssetStore.App.ServiceCollectionExtensions).Assembly];
}
