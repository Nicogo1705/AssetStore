@inherits LayoutComponentBase
@inject AppEnvironment Env
@inject UpdateService Updater
@inject AppInfo AppFacts

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="">
            <span class="brand-mark">◆</span>
            <span class="brand-text">Stride <strong>Asset Store</strong></span>
        </a>
        <span class="brand-tag">unofficial · prototype</span>
        <a class="brand-link" href="https://stride3d.net" target="_blank" rel="noopener">Stride website ↗</a>
        <nav class="app-nav">
            @if (Env.InstallAvailable)
            {
                <a href="projects" style="margin-right:1rem">My projects</a>
            }
            <a href="publish" style="margin-right:1rem">Manage</a>
            <a href="about" style="margin-right:1rem">Info</a>
            @if (Env.Initialized && !Env.IsLocal)
            {
                <a class="btn-dl" href="download">⬇ Download app</a>
            }
            @if (Env.Initialized)
            {
                <span class="env @(Env.IsLocal ? "local" : "online")"
                      title="@(Env.IsLocal ? "Running locally — install available" : "Online store — get the desktop app for one-click install")">
                    ● @(Env.IsLocal ? "local" : "online")
                </span>
            }
        </nav>
    </header>

    @if (Env.InstallAvailable && Updater.UpdateAvailable)
    {
        <div class="update-banner">
            <span>⬆ <strong>Update available</strong> — v@(Updater.LatestVersion) is out (you're on v@(Updater.CurrentVersion)).</span>
            <span class="update-actions">
                @if (Updater.DownloadUrl is not null)
                {
                    <a class="btn primary" href="@Updater.DownloadUrl">⬇ Download update</a>
                }
                @if (Updater.ReleaseUrl is not null)
                {
                    <a class="btn" href="@Updater.ReleaseUrl" target="_blank" rel="noopener">Release notes</a>
                }
            </span>
        </div>
    }

    <main class="app-main">
        @Body
    </main>

    <footer class="app-footer">
        <a href="@GitLinks.ReleasesLatest(AppFacts.Repo)" target="_blank" rel="noopener" class="ver-link">v@(Updater.CurrentVersion)</a>
        @* build/version, shown everywhere for clarity *@
        · Decentralized · git-native · MIT
    </footer>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Env.InitializeAsync();
            StateHasChanged();

            // Only the local/desktop build can install updates in place; check there.
            if (Env.InstallAvailable)
            {
                await Updater.CheckAsync();
                StateHasChanged();
            }
        }
    }
}
