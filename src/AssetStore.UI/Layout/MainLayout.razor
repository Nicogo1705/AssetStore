@inherits LayoutComponentBase
@inject AppEnvironment Env

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="">
            <span class="brand-mark">◆</span>
            <span class="brand-text">Stride <strong>Asset Store</strong></span>
        </a>
        <span class="brand-tag">prototype</span>
        <a class="brand-link" href="https://stride3d.net" target="_blank" rel="noopener">Stride official website ↗</a>
        <nav class="app-nav">
            @if (Env.InstallAvailable)
            {
                <a href="installed" style="margin-right:1rem">Installed</a>
            }
            <a href="publish" style="margin-right:1rem">Publish</a>
            <a href="about" style="margin-right:1rem">Info</a>
            @if (Env.Initialized)
            {
                <span class="env @(Env.IsLocal ? "local" : "online")"
                      title="@(Env.IsLocal ? "Running locally — install available" : "Online store — copy commands to install")">
                    ● @(Env.IsLocal ? "local" : "online")
                </span>
            }
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>

    <footer class="app-footer">
        Decentralized · git-native · MIT
    </footer>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Env.InitializeAsync();
            StateHasChanged();
        }
    }
}
