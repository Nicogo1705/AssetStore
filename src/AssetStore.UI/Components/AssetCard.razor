<a class="card" href="@($"asset?id={Uri.EscapeDataString(Asset.Id)}")">
    <div class="card-thumb">
        @Initial
        @if (ThumbUrl is not null)
        {
            <img class="thumb-img" src="@ThumbUrl" alt="" loading="lazy"
                 onload="this.style.display=''" onerror="this.style.display='none'" />
        }
    </div>
    <div class="card-body">
        <div class="card-title">@Asset.Manifest.Name</div>
        <div class="card-desc">@Asset.Manifest.Description</div>
        <div class="card-meta">
            <span class="badge cat">@Asset.Manifest.Category</span>
            @if (Asset.Latest.DetectedStrideVersion is not null)
            {
                <span class="badge stride">Stride @Asset.Latest.DetectedStrideVersion</span>
            }
            @if (Asset.Certified.Count > 0)
            {
                <span class="badge certified">certified</span>
            }
            @if (Asset.Manifest.Nuget is not null)
            {
                <span class="badge nuget">NuGet</span>
            }
            @if (Asset.Stars is { } stars)
            {
                <span class="badge stars">★ @stars</span>
            }
            @if (Asset.ValidationStatus is "error" or "unavailable")
            {
                <span class="badge warn">⚠ @Asset.ValidationStatus</span>
            }
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired]
    public IndexedAsset Asset { get; set; } = default!;

    private string Initial =>
        string.IsNullOrEmpty(Asset.Manifest.Name) ? "?" : Asset.Manifest.Name[..1].ToUpperInvariant();

    // thumbnail/media paths are relative to the repository root (display-only, not cloned into projects).
    private string? ThumbUrl =>
        string.IsNullOrEmpty(Asset.Manifest.Thumbnail)
            ? null
            : GitLinks.RawRepoFile(Asset.Repo, Asset.Latest.Commit, Asset.Manifest.Thumbnail);
}
