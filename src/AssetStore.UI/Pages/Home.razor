@page "/"
@implements IDisposable
@inject CatalogState State

<PageTitle>Stride Asset Store</PageTitle>

<h1 class="sr-only">Browse assets</h1>

@if (State.Loading)
{
    <p class="notice">Loading catalog…</p>
}
else if (State.Error is not null)
{
    <p class="notice error">Failed to load catalog: @State.Error</p>
}
else if (State.Catalog is not null)
{
    var catalog = State.Catalog;
    var results = catalog.Query(BuildQuery());

    @if (State.FromCache)
    {
        <div class="cache-note">⚠ Offline — showing the last cached catalog.</div>
    }

    <div class="toolbar">
        <input type="text" placeholder="Search assets…" aria-label="Search assets" @bind="_text" @bind:event="oninput" />
        <select @bind="_category" aria-label="Filter by category">
            <option value="">All categories</option>
            @foreach (var c in catalog.Categories)
            {
                <option value="@c">@c</option>
            }
        </select>
        <select @bind="_stride" aria-label="Filter by minimum Stride version">
            <option value="">Any Stride</option>
            @foreach (var sv in catalog.StrideVersions)
            {
                <option value="@sv">≥ @sv</option>
            }
        </select>
        <select @bind="_sort" aria-label="Sort by">
            <option value="Name">Sort: Name</option>
            <option value="Category">Sort: Category</option>
            <option value="Stars">Sort: Stars</option>
        </select>
        <label><input type="checkbox" @bind="_searchDescription" /> Search descriptions</label>
        <label><input type="checkbox" @bind="_certifiedOnly" /> Certified only</label>
    </div>

    <p class="tag">@results.Count asset(s)@(catalog.Assets.Count > 0 ? $" · catalog {catalog.GeneratedAt}" : "")</p>

    @if (catalog.Assets.Count == 0)
    {
        <p class="notice">No assets published yet — be the first to <a href="publish">publish one</a>.</p>
    }
    else if (results.Count == 0)
    {
        <p class="notice">No assets match your filters.</p>
    }
    else
    {
        <div class="grid">
            @foreach (var asset in results)
            {
                <AssetCard Asset="asset" @key="asset.Id" />
            }
        </div>
    }
}

@code {
    private string _text = "";
    private string _category = "";
    private string _sort = "Name";
    private string _stride = "";
    private bool _certifiedOnly;
    private bool _searchDescription = true;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        await State.EnsureLoadedAsync();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private CatalogQuery BuildQuery() => new()
    {
        Text = _text,
        Category = string.IsNullOrEmpty(_category) ? null : _category,
        CertifiedOnly = _certifiedOnly,
        SearchDescription = _searchDescription,
        StrideVersion = string.IsNullOrEmpty(_stride) ? null : _stride,
        StrideMatch = StrideMatch.AtLeast,
        SortBy = Enum.Parse<CatalogSort>(_sort),
    };

    public void Dispose() => State.Changed -= OnChanged;
}
