@page "/asset"
@implements IDisposable
@using Markdig
@using System.Text.Json
@inject CatalogState State
@inject AppEnvironment Env
@inject HttpClient Http
@inject RegistryOptions Registry

@if (State.Loading)
{
    <p class="notice">Loading…</p>
}
else if (Asset is null)
{
    <a class="back" href="">← Back</a>
    <p class="notice error">Asset '@Id' was not found in the catalog.</p>
}
else
{
    var m = Asset.Manifest;
    var v = Asset.Latest;
    <PageTitle>@m.Name — Stride Asset Store</PageTitle>

    <a class="back" href="">← Back to catalog</a>

    <div class="detail">
        <div class="detail-head">
            <div class="detail-thumb">
                @(m.Name.Length > 0 ? m.Name[..1].ToUpperInvariant() : "?")
                @if (ThumbUrl is not null)
                {
                    <img class="thumb-img" src="@ThumbUrl" alt="" onload="this.style.display=''" onerror="this.style.display='none'" />
                }
            </div>
            <div>
                <h1>@m.Name</h1>
                <div class="sub">
                    @m.Id · by
                    @for (var i = 0; i < m.Authors.Count; i++)
                    {
                        var a = m.Authors[i];
                        @(i > 0 ? ", " : " ")
                        @if (!string.IsNullOrWhiteSpace(a.Url))
                        {
                            <a href="@a.Url" target="_blank" rel="noopener">@a.Name</a>
                        }
                        else
                        {
                            <text>@a.Name</text>
                        }
                    }
                </div>
                <div class="card-meta" style="margin-top:.5rem">
                    <span class="badge cat">@m.Category</span>
                    @if (v.DetectedStrideVersion is not null)
                    {
                        <span class="badge stride">Stride @v.DetectedStrideVersion</span>
                    }
                    @if (Asset.Certified.Count > 0)
                    {
                        <span class="badge certified">certified</span>
                    }
                    @if (m.Nuget is not null)
                    {
                        <span class="badge nuget">NuGet</span>
                    }
                    @if (Asset.Stars is { } stars)
                    {
                        <span class="badge stars">★ @stars</span>
                    }
                </div>
                <div style="margin-top:.6rem; display:flex; gap:.5rem; flex-wrap:wrap">
                    <a class="btn" href="@Asset.Repo" target="_blank" rel="noopener">★ Star on GitHub</a>
                    <a class="btn" href="@GitLinks.Forks(Asset.Repo)" target="_blank" rel="noopener">⑂ View forks</a>
                    <a class="btn" href="@GitLinks.NewIssue(Asset.Repo)" target="_blank" rel="noopener">⚠ Create an issue</a>
                    <a class="btn" href="@GitLinks.Releases(Asset.Repo)" target="_blank" rel="noopener">🏷 Changelog</a>
                </div>
            </div>
        </div>

        @if (_readme is { } readmeHtml)
        {
            <div class="readme">@readmeHtml</div>
        }
        else
        {
            <p>@m.Description</p>
        }

        @if (MediaUrls.Count > 0)
        {
            <section class="gallery">
                @for (var i = 0; i < MediaUrls.Count; i++)
                {
                    var idx = i;
                    var url = MediaUrls[idx];
                    <button type="button" class="shot" @onclick="() => OpenLightbox(idx)" title="Open">
                        @if (IsVideo(url))
                        {
                            <video src="@url" muted preload="metadata"></video>
                            <span class="shot-play">▶</span>
                        }
                        else
                        {
                            <img src="@url" loading="lazy" alt="Media @(idx + 1)" onerror="this.closest('.shot').style.display='none'" />
                        }
                    </button>
                }
            </section>
        }

        @if (Asset.ValidationStatus is not "ok")
        {
            var isError = Asset.ValidationStatus is "error" or "unavailable";
            <div class="validation @(isError ? "error" : "warning")">
                <div class="validation-head">
                    <span class="vbig">@(isError ? "⛔" : "⚠️")</span>
                    <span>@(isError ? "This asset failed validation and may be broken" : "This asset has warnings")</span>
                </div>
                @if (ParsedMessages().Count > 0)
                {
                    <ul class="validation-list">
                        @foreach (var line in ParsedMessages())
                        {
                            <li class="vline @(line.IsError ? "err" : "warn")">
                                <span class="vico">@(line.IsError ? "✗" : "⚠")</span>
                                <span><span class="vcode">@line.Code</span> @line.Text</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }

        @if (_fileTree is not null)
        {
            <section>
                <h2>Files (@_fileCount)</h2>
                <p class="install-hint">What gets cloned into your project — the asset's <span class="mono">AssetData/</span> at the pinned commit.</p>
                <div class="filetree">
                    @RenderNode(_fileTree)
                </div>
            </section>
        }

        <section>
            <h2>Add to your project</h2>

            <label class="field" style="margin-bottom:.35rem">Version
                <select class="ipt" @bind="_versionRef">
                    <option value="@Asset.Latest.Ref">latest — @Asset.Latest.Ref branch (rolling)</option>
                    @foreach (var ver in Asset.Versions)
                    {
                        <option value="@ver.Tag">@ver.Version — tag@(IsCertified(ver.Commit) ? " ✓ certified" : "")</option>
                    }
                </select>
            </label>
            <p class="install-hint" style="margin-bottom:.7rem">
                @if (OnLatest)
                {
                    <text>Tracking the <strong>@Asset.Latest.Ref</strong> branch — always its newest commit (<span class="mono">@Short(ActiveCommit)</span>). A branch is never certified; pick a tag for a pinned, reviewable version.</text>
                }
                else
                {
                    <text>Tag <strong>@_versionRef</strong> — pinned at <span class="mono">@Short(ActiveCommit)</span>.</text>
                    @if (IsCertified(ActiveCommit))
                    {
                        <span class="badge certified" style="margin-left:.4rem">✓ certified</span>
                    }
                    else
                    {
                        <text> (not certified)</text>
                    }
                }
            </p>

            @if (Env.InstallAvailable)
            {
                <div class="install-cta">
                    <a class="btn primary" href="@($"install?id={Uri.EscapeDataString(Asset.Id)}&mode={EffectiveMode}")">⤓ Install into a project…</a>
                    <span class="install-hint">one-click: @(EffectiveMode == "nuget" ? "add the NuGet package" : "clone + add a ProjectReference")</span>
                </div>
            }
            else
            {
                <p class="install-hint">Browsing the online store — open the desktop app for one-click install.</p>
            }

            <div class="modes">
                <button class="mode @(EffectiveMode == "local" ? "active" : "")" @onclick='() => _mode = "local"'>
                    Source &amp; ProjectReference
                </button>
                <button class="mode @(EffectiveMode == "nuget" ? "active" : "") @(m.Nuget is null ? "disabled" : "")"
                        disabled="@(m.Nuget is null)"
                        title="@(m.Nuget is null ? "This asset is not published on NuGet" : "")"
                        @onclick='() => { if (m.Nuget is not null) _mode = "nuget"; }'>
                    NuGet package
                </button>
            </div>

            @if (EffectiveMode == "nuget" && m.Nuget is not null)
            {
                <p class="mode-desc">Reference the published package — no source is cloned.</p>
                <div class="cmd">
                    <code>@GitLinks.AddPackageCommand(m.Nuget.PackageId, m.Nuget.PackageVersion)</code>
                    <button class="btn" @onclick="() => Copy(GitLinks.AddPackageCommand(m.Nuget.PackageId, m.Nuget.PackageVersion))">Copy</button>
                </div>
            }
            else
            {
                <p class="mode-desc">Clone the source and add a <code>&lt;ProjectReference&gt;</code> — you can compile and tweak it locally.</p>

                <div class="install-grid">
                    <div class="cmd">
                        <code>@CloneCommand</code>
                        <button class="btn" @onclick="() => Copy(CloneCommand)">Copy</button>
                    </div>

                    <div class="cmd">
                        <a class="btn" href="@GitLinks.ArchiveZip(Asset.Repo, ActiveCommit)">⬇ Download .zip</a>
                        <span class="install-hint">pinned at <span class="mono">@Short(ActiveCommit)</span></span>
                    </div>
                </div>
            }

        </section>

        <section>
            <h2>Details</h2>
            <div class="kv">
                <span class="k">License</span><span>@m.License</span>
                <span class="k">Stride version</span><span>@(v.DetectedStrideVersion ?? "unknown")</span>
                <span class="k">.NET</span><span>@(v.TargetFramework ?? "unknown")</span>
                <span class="k">Default import</span><span>@(m.DefaultImport ?? "local")</span>
                <span class="k">Repository</span><span><a href="@GitLinks.TreeAtCommit(Asset.Repo, ActiveRef)" target="_blank" rel="noopener">@Asset.Repo</a></span>
                <span class="k">Pinned commit</span><span class="mono">@ActiveCommit</span>
                <span class="k">Content hash</span><span class="mono">@(string.IsNullOrEmpty(v.ContentHash) ? "-" : v.ContentHash[..16])…</span>
                <span class="k">Size</span><span>@FormatSize(v.SizeBytes)</span>
                @if (m.Tags.Count > 0)
                {
                    <span class="k">Tags</span><span>@string.Join(", ", m.Tags)</span>
                }
                @if (v.ResolvedDependencies.Count > 0)
                {
                    <span class="k">Dependencies</span>
                    <span>
                        @foreach (var dep in v.ResolvedDependencies)
                        {
                            <a href="@($"asset?id={Uri.EscapeDataString(dep)}")">@dep</a> <text> </text>
                        }
                    </span>
                }
            </div>
        </section>

        @if (v.ExternalDependencies.Count > 0)
        {
            <section>
                <h2>External dependencies</h2>
                <p class="install-hint">NuGet packages the project references (from the latest <strong>@Asset.Latest.Ref</strong> — not store assets).</p>
                <div class="extdeps">
                    @foreach (var pkg in v.ExternalDependencies)
                    {
                        <div class="extdep">
                            <span class="mono extdep-name">@pkg.Name</span>
                            <span class="mono extdep-ver">@(pkg.Version ?? "—")</span>
                        </div>
                    }
                </div>
            </section>
        }

        @if (Asset.Certified.Count > 0)
        {
            <section>
                <h2>Certified versions</h2>
                <div class="kv">
                    @foreach (var c in Asset.Certified)
                    {
                        <span class="k">v@(c.Version)</span>
                        <span class="mono">@Short(c.Commit) @(c.CertifiedAt is not null ? $"· {c.CertifiedAt}" : "")</span>
                    }
                </div>
            </section>
        }

        <p class="install-hint" style="margin-top:1.4rem">
            Something wrong with this asset?
            <a href="@GitLinks.ReportAsset(Registry.Owner, Registry.Repo, Asset.Id, Asset.Repo)" target="_blank" rel="noopener">🚩 Report it to the registry</a>.
        </p>

        @if (_lightbox is { } li && li >= 0 && li < MediaUrls.Count)
        {
            <div class="lightbox" @onclick="CloseLightbox">
                <button class="lb-nav prev" @onclick:stopPropagation="true" @onclick="PrevShot" title="Previous">‹</button>
                @if (IsVideo(MediaUrls[li]))
                {
                    <video class="lb-img" src="@MediaUrls[li]" controls autoplay @onclick:stopPropagation="true"></video>
                }
                else
                {
                    <img class="lb-img" src="@MediaUrls[li]" alt="" @onclick:stopPropagation="true" />
                }
                <button class="lb-nav next" @onclick:stopPropagation="true" @onclick="NextShot" title="Next">›</button>
                <button class="lb-close" @onclick="CloseLightbox" title="Close">✕</button>
                <div class="lb-count" @onclick:stopPropagation="true">@(li + 1) / @MediaUrls.Count</div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public string? Id { get; set; }

    private string? _versionRef;
    private string? _mode;
    private int? _lightbox;

    private IndexedAsset? Asset => string.IsNullOrEmpty(Id) ? null : State.Find(Id);

    private IReadOnlyList<string> MediaUrls =>
        Asset is null
            ? []
            : Asset.Manifest.Media
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Select(s => GitLinks.RawAssetFile(Asset.Repo, Asset.Latest.Commit, s))
                .ToList();

    private static readonly string[] VideoExtensions = [".mp4", ".webm", ".ogg", ".ogv", ".mov", ".m4v"];

    private static bool IsVideo(string url)
    {
        var path = url.Split('?', '#')[0];
        return VideoExtensions.Any(ext => path.EndsWith(ext, StringComparison.OrdinalIgnoreCase));
    }

    private void OpenLightbox(int index) => _lightbox = index;

    private void CloseLightbox() => _lightbox = null;

    private void NextShot()
    {
        if (_lightbox is { } i && MediaUrls.Count > 0)
        {
            _lightbox = (i + 1) % MediaUrls.Count;
        }
    }

    private void PrevShot()
    {
        if (_lightbox is { } i && MediaUrls.Count > 0)
        {
            _lightbox = (i - 1 + MediaUrls.Count) % MediaUrls.Count;
        }
    }

    // Default to NuGet only when the asset prefers it and actually publishes a package.
    private string EffectiveMode =>
        _mode ?? (Asset?.Manifest is { Nuget: not null, DefaultImport: "nuget" } ? "nuget" : "local");

    private string ActiveRef => _versionRef ?? Asset!.Latest.Ref;

    private string ActiveCommit =>
        _versionRef is null || _versionRef == Asset!.Latest.Ref
            ? Asset!.Latest.Commit
            : Asset!.Versions.FirstOrDefault(v => v.Tag == _versionRef)?.Commit ?? Asset.Latest.Commit;

    private bool OnLatest => _versionRef is null || _versionRef == Asset!.Latest.Ref;

    private static string Short(string commit) => commit.Length >= 7 ? commit[..7] : commit;

    private string CloneCommand => $"git clone --branch {ActiveRef} {Asset!.Repo}";

    private sealed record VLine(bool IsError, string Code, string Text);

    private List<VLine> ParsedMessages()
    {
        var list = new List<VLine>();
        foreach (var m in Asset!.ValidationMessages)
        {
            var isError = m.StartsWith("[Error]", StringComparison.Ordinal);
            var body = m.StartsWith('[') && m.Contains(']') ? m[(m.IndexOf(']') + 1)..].Trim() : m;
            var colon = body.IndexOf(": ", StringComparison.Ordinal);
            list.Add(new VLine(isError, colon > 0 ? body[..colon] : "", colon > 0 ? body[(colon + 2)..] : body));
        }

        return list;
    }

    private bool IsCertified(string commit) =>
        Asset!.Certified.Any(c => string.Equals(c.Commit, commit, StringComparison.Ordinal));

    private MarkupString? _readme;
    private TreeNode? _fileTree;
    private int _fileCount;
    private string? _loadedCommit;

    private sealed class TreeNode
    {
        public string Name { get; init; } = "";
        public bool IsFolder { get; init; }
        public long Size { get; set; }
        public SortedDictionary<string, TreeNode> Children { get; } = new(StringComparer.OrdinalIgnoreCase);
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reset per-asset selections when navigating between assets.
        _versionRef = null;
        _mode = null;
        _lightbox = null;
        await LoadRepoDataAsync();
    }

    /// <summary>Fetches the asset's README (rendered) and its AssetData/ file list at the pinned commit.</summary>
    private async Task LoadRepoDataAsync()
    {
        var asset = Asset;
        if (asset is null)
        {
            _readme = null;
            _fileTree = null;
            _fileCount = 0;
            _loadedCommit = null;
            return;
        }

        if (_loadedCommit == asset.Latest.Commit)
        {
            return; // already loaded for this asset
        }

        _loadedCommit = asset.Latest.Commit;
        _readme = null;
        _fileTree = null;
        _fileCount = 0;

        // README.md → rendered Markdown (falls back to the short description if absent).
        try
        {
            var markdown = await Http.GetStringAsync(GitLinks.RawAssetFile(asset.Repo, asset.Latest.Commit, "README.md"));
            if (!string.IsNullOrWhiteSpace(markdown))
            {
                // DisableHtml() strips raw HTML so a third-party README can't inject scripts.
                var pipeline = new MarkdownPipelineBuilder().DisableHtml().UseAdvancedExtensions().Build();
                _readme = (MarkupString)Markdown.ToHtml(markdown, pipeline);
            }
        }
        catch
        {
            _readme = null;
        }

        // AssetData/ file tree (what actually gets cloned) via the GitHub API.
        var treeApi = GitLinks.TreeApi(asset.Repo, asset.Latest.Commit);
        if (treeApi is not null)
        {
            try
            {
                using var request = new HttpRequestMessage(HttpMethod.Get, treeApi);
                request.Headers.UserAgent.ParseAdd("StrideAssetStore"); // GitHub's API requires a User-Agent
                using var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
                    var files = doc.RootElement.GetProperty("tree").EnumerateArray()
                        .Where(e => e.GetProperty("type").GetString() == "blob"
                            && e.GetProperty("path").GetString()!.StartsWith("AssetData/", StringComparison.Ordinal))
                        .Select(e => (
                            Path: e.GetProperty("path").GetString()!["AssetData/".Length..],
                            Size: e.TryGetProperty("size", out var sz) ? sz.GetInt64() : 0L))
                        .ToList();
                    _fileCount = files.Count;
                    _fileTree = files.Count > 0 ? BuildTree(files) : null;
                }
            }
            catch
            {
                _fileTree = null;
                _fileCount = 0;
            }
        }
    }

    private static TreeNode BuildTree(IEnumerable<(string Path, long Size)> files)
    {
        var root = new TreeNode { IsFolder = true };
        foreach (var (path, size) in files)
        {
            var parts = path.Split('/');
            var node = root;
            for (var i = 0; i < parts.Length; i++)
            {
                var isFile = i == parts.Length - 1;
                if (!node.Children.TryGetValue(parts[i], out var child))
                {
                    child = new TreeNode { Name = parts[i], IsFolder = !isFile };
                    node.Children[parts[i]] = child;
                }

                if (isFile)
                {
                    child.Size = size;
                }

                node = child;
            }
        }

        return root;
    }

    // Folders first (open by default), then files; recurses into subfolders.
    private RenderFragment RenderNode(TreeNode node) => @<text>
        @foreach (var child in node.Children.Values.OrderByDescending(c => c.IsFolder).ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
        {
            @if (child.IsFolder)
            {
                <details class="tree-folder">
                    <summary><span class="tree-ico">📁</span> @child.Name</summary>
                    <div class="tree-children">@RenderNode(child)</div>
                </details>
            }
            else
            {
                <div class="tree-file">
                    <span class="mono"><span class="tree-ico">📄</span> @child.Name</span>
                    <span class="mono filesize">@FormatSize(child.Size)</span>
                </div>
            }
        }
    </text>;

    private string? ThumbUrl =>
        Asset is not null && !string.IsNullOrEmpty(Asset.Manifest.Thumbnail)
            ? GitLinks.RawAssetFile(Asset.Repo, Asset.Latest.Commit, Asset.Manifest.Thumbnail)
            : null;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        await State.EnsureLoadedAsync();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task Copy(string text) => await Env.CopyAsync(text);

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024.0 / 1024.0:0.0} MB"
        : bytes >= 1024 ? $"{bytes / 1024.0:0.0} KB"
        : $"{bytes} B";

    public void Dispose() => State.Changed -= OnChanged;
}
