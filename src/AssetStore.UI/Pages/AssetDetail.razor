@page "/asset"
@implements IDisposable
@inject CatalogState State
@inject AppEnvironment Env

@if (State.Loading)
{
    <p class="notice">Loading…</p>
}
else if (Asset is null)
{
    <a class="back" href="">← Back</a>
    <p class="notice error">Asset '@Id' was not found in the catalog.</p>
}
else
{
    var m = Asset.Manifest;
    var v = Asset.Latest;
    <PageTitle>@m.Name — Stride Asset Store</PageTitle>

    <a class="back" href="">← Back to catalog</a>

    <div class="detail">
        <div class="detail-head">
            <div class="detail-thumb">
                @(m.Name.Length > 0 ? m.Name[..1].ToUpperInvariant() : "?")
                @if (ThumbUrl is not null)
                {
                    <img class="thumb-img" src="@ThumbUrl" alt="" onerror="this.style.display='none'" />
                }
            </div>
            <div>
                <h1>@m.Name</h1>
                <div class="sub">@m.Id · v@(m.Version) · by @string.Join(", ", m.Authors.Select(a => a.Name))</div>
                <div class="card-meta" style="margin-top:.5rem">
                    <span class="badge cat">@m.Category</span>
                    @if (v.DetectedStrideVersion is not null)
                    {
                        <span class="badge stride">Stride @v.DetectedStrideVersion</span>
                    }
                    @if (Asset.Certified.Count > 0)
                    {
                        <span class="badge certified">certified</span>
                    }
                    @if (m.Nuget is not null)
                    {
                        <span class="badge nuget">NuGet</span>
                    }
                    @if (Asset.Stars is { } stars)
                    {
                        <span class="badge stars">★ @stars</span>
                    }
                </div>
                <div style="margin-top:.6rem">
                    <a class="btn" href="@Asset.Repo" target="_blank" rel="noopener">★ Star on GitHub</a>
                </div>
            </div>
        </div>

        <p>@m.Description</p>

        @if (Asset.ValidationStatus is not "ok")
        {
            var isError = Asset.ValidationStatus is "error" or "unavailable";
            <div class="validation @(isError ? "error" : "warning")">
                <div class="validation-head">
                    <span class="vbig">@(isError ? "⛔" : "⚠️")</span>
                    <span>@(isError ? "This asset failed validation and may be broken" : "This asset has warnings")</span>
                </div>
                @if (ParsedMessages().Count > 0)
                {
                    <ul class="validation-list">
                        @foreach (var line in ParsedMessages())
                        {
                            <li class="vline @(line.IsError ? "err" : "warn")">
                                <span class="vico">@(line.IsError ? "✗" : "⚠")</span>
                                <span><span class="vcode">@line.Code</span> @line.Text</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        }

        <section>
            <h2>Add to your project</h2>

            @if (Asset.Versions.Count > 0)
            {
                <label class="field" style="margin-bottom:.7rem">Version
                    <select class="ipt" @bind="_versionRef">
                        <option value="@Asset.Latest.Ref">latest (@Asset.Latest.Ref)</option>
                        @foreach (var ver in Asset.Versions)
                        {
                            <option value="@ver.Tag">@ver.Version@(IsCertified(ver.Commit) ? " — certified" : "")</option>
                        }
                    </select>
                </label>
            }

            <div class="modes">
                <button class="mode @(EffectiveMode == "local" ? "active" : "")" @onclick='() => _mode = "local"'>
                    Source &amp; ProjectReference
                </button>
                <button class="mode @(EffectiveMode == "nuget" ? "active" : "") @(m.Nuget is null ? "disabled" : "")"
                        disabled="@(m.Nuget is null)"
                        title="@(m.Nuget is null ? "This asset is not published on NuGet" : "")"
                        @onclick='() => { if (m.Nuget is not null) _mode = "nuget"; }'>
                    NuGet package
                </button>
            </div>

            @if (EffectiveMode == "nuget" && m.Nuget is not null)
            {
                <p class="mode-desc">Reference the published package — no source is cloned.</p>
                <div class="cmd">
                    <code>@GitLinks.AddPackageCommand(m.Nuget.PackageId, m.Nuget.PackageVersion)</code>
                    <button class="btn" @onclick="() => Copy(GitLinks.AddPackageCommand(m.Nuget.PackageId, m.Nuget.PackageVersion))">Copy</button>
                </div>
            }
            else
            {
                <p class="mode-desc">Clone the source and add a <code>&lt;ProjectReference&gt;</code> — you can compile and tweak it locally.</p>

                <div class="install-grid">
                    <div class="cmd">
                        <code>@CloneCommand</code>
                        <button class="btn" @onclick="() => Copy(CloneCommand)">Copy</button>
                    </div>

                    <div class="cmd">
                        <a class="btn" href="@GitLinks.ArchiveZip(Asset.Repo, ActiveCommit)">⬇ Download .zip</a>
                        <span class="install-hint">pinned at <span class="mono">@ActiveCommit[..7]</span></span>
                    </div>
                </div>
            }

            @if (Env.InstallAvailable && EffectiveMode == "local")
            {
                <div class="install-cta">
                    <a class="btn primary" href="@($"install?id={Uri.EscapeDataString(Asset.Id)}")">⤓ Install into a project…</a>
                    <span class="install-hint">pick a .sln / .csproj and add the reference</span>
                </div>
            }
            else if (!Env.InstallAvailable)
            {
                <p class="install-hint">Browsing the online store — open the desktop app for one-click install.</p>
            }
        </section>

        <section>
            <h2>Details</h2>
            <div class="kv">
                <span class="k">License</span><span>@m.License</span>
                <span class="k">Stride version</span><span>@(v.DetectedStrideVersion ?? "unknown")</span>
                <span class="k">Default import</span><span>@(m.DefaultImport ?? "local")</span>
                <span class="k">Repository</span><span><a href="@GitLinks.TreeAtCommit(Asset.Repo, v.Commit)" target="_blank" rel="noopener">@Asset.Repo</a></span>
                <span class="k">Pinned commit</span><span class="mono">@ActiveCommit</span>
                <span class="k">Content hash</span><span class="mono">@(string.IsNullOrEmpty(v.ContentHash) ? "-" : v.ContentHash[..16])…</span>
                <span class="k">Size</span><span>@FormatSize(v.SizeBytes)</span>
                @if (m.Tags.Count > 0)
                {
                    <span class="k">Tags</span><span>@string.Join(", ", m.Tags)</span>
                }
                @if (v.ResolvedDependencies.Count > 0)
                {
                    <span class="k">Dependencies</span>
                    <span>
                        @foreach (var dep in v.ResolvedDependencies)
                        {
                            <a href="@($"asset?id={Uri.EscapeDataString(dep)}")">@dep</a> <text> </text>
                        }
                    </span>
                }
            </div>
        </section>

        @if (Asset.Certified.Count > 0)
        {
            <section>
                <h2>Certified versions</h2>
                <div class="kv">
                    @foreach (var c in Asset.Certified)
                    {
                        <span class="k">v@(c.Version)</span>
                        <span class="mono">@c.Commit[..7] @(c.CertifiedAt is not null ? $"· {c.CertifiedAt}" : "")</span>
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public string? Id { get; set; }

    private string? _versionRef;
    private string? _mode;

    private IndexedAsset? Asset => string.IsNullOrEmpty(Id) ? null : State.Find(Id);

    // Default to NuGet only when the asset prefers it and actually publishes a package.
    private string EffectiveMode =>
        _mode ?? (Asset?.Manifest is { Nuget: not null, DefaultImport: "nuget" } ? "nuget" : "local");

    private string ActiveRef => _versionRef ?? Asset!.Latest.Ref;

    private string ActiveCommit =>
        _versionRef is null || _versionRef == Asset!.Latest.Ref
            ? Asset!.Latest.Commit
            : Asset!.Versions.FirstOrDefault(v => v.Tag == _versionRef)?.Commit ?? Asset.Latest.Commit;

    private string CloneCommand => $"git clone --branch {ActiveRef} {Asset!.Repo}";

    private sealed record VLine(bool IsError, string Code, string Text);

    private List<VLine> ParsedMessages()
    {
        var list = new List<VLine>();
        foreach (var m in Asset!.ValidationMessages)
        {
            var isError = m.StartsWith("[Error]", StringComparison.Ordinal);
            var body = m.StartsWith('[') && m.Contains(']') ? m[(m.IndexOf(']') + 1)..].Trim() : m;
            var colon = body.IndexOf(": ", StringComparison.Ordinal);
            list.Add(new VLine(isError, colon > 0 ? body[..colon] : "", colon > 0 ? body[(colon + 2)..] : body));
        }

        return list;
    }

    private bool IsCertified(string commit) =>
        Asset!.Certified.Any(c => string.Equals(c.Commit, commit, StringComparison.Ordinal));

    protected override void OnParametersSet()
    {
        // Reset per-asset selections when navigating between assets.
        _versionRef = null;
        _mode = null;
    }

    private string? ThumbUrl =>
        Asset is not null && !string.IsNullOrEmpty(Asset.Manifest.Thumbnail)
            ? GitLinks.RawAssetFile(Asset.Repo, Asset.Latest.Commit, Asset.Manifest.Thumbnail)
            : null;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnChanged;
        await State.EnsureLoadedAsync();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task Copy(string text) => await Env.CopyAsync(text);

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024.0 / 1024.0:0.0} MB"
        : bytes >= 1024 ? $"{bytes / 1024.0:0.0} KB"
        : $"{bytes} B";

    public void Dispose() => State.Changed -= OnChanged;
}
