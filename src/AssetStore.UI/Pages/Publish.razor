@page "/publish"
@implements IDisposable
@using System.Text.RegularExpressions
@inject GitHubAuth Auth
@inject GitHubPublisher Publisher

<PageTitle>Publish — Stride Asset Store</PageTitle>

<a class="back" href="">← Back to catalog</a>
<h1 style="margin:.2rem 0 1rem">Publish an asset</h1>

<section class="panel">
    <h2>0 · Build &amp; include your manifest in your repo</h2>
    <p class="install-hint">
        Your asset lives in <strong>your own public GitHub repo</strong> with an <code>AssetData/</code> folder
        containing <code>manifest.json</code> (+ README, thumbnail, and your Stride project). <strong>Commit
        &amp; push it</strong> before submitting — the registry validates your repo at the tracked ref, so the
        manifest must already be there.
    </p>
    <a class="btn" href="manifest-generator">🧩 Open the manifest generator →</a>
    <p class="install-hint" style="margin-top:.4rem">
        Optional helper to write <code>manifest.json</code>. If your asset is already prepared, skip straight to submit.
    </p>
</section>

<section class="panel">
    <h2>1 · Sign in to GitHub</h2>
    @if (Auth.IsSignedIn)
    {
        <p>Signed in as <strong>@@@Auth.Login</strong>. <button class="btn" @onclick="SignOut">Sign out</button></p>
    }
    else
    {
        <p class="install-hint">
            Browser apps can't use GitHub's device/OAuth flow (no CORS), so paste a token.
            Prefer a <a href="https://github.com/settings/personal-access-tokens/new" target="_blank" rel="noopener">fine-grained token</a>
            limited to the registry repo (or your fork of it), with <strong>Contents</strong> + <strong>Pull requests: read/write</strong>
            and a short expiry — or a classic token with the <code>public_repo</code> scope.
            It is stored <strong>encrypted</strong> in your browser and wiped when you close the tab; it is sent only to <code>api.github.com</code>.
        </p>
        <div class="cmd">
            <input type="password" placeholder="ghp_…" @bind="_token" style="flex:1" class="ipt" />
            <button class="btn primary" @onclick="SignIn" disabled="@_busy">Sign in</button>
        </div>
        @if (_authError is not null)
        {
            <p class="notice error">@_authError</p>
        }
    }
</section>

<section class="panel">
    <h2>2 · Submit to the registry</h2>
    <p class="install-hint">
        Opens a pull request adding <code>registry/@(AssetId.IsValid(_id) ? _id : "&lt;id&gt;").json</code> to
        AssetContainer. No need to re-enter your manifest — the bot reads it from your repo.
    </p>
    <div class="form">
        <label>Asset id (reverse-DNS)<input class="ipt" @bind="_id" @bind:event="oninput" placeholder="com.you.cool-asset" /></label>
        <label class="wide">Asset repo URL<input class="ipt" @bind="_repoUrl" @bind:event="oninput" placeholder="https://github.com/you/CoolAsset" /></label>
        <label>Tracked ref<input class="ipt" @bind="_ref" placeholder="main" /></label>
    </div>

    <button class="btn primary" @onclick="Submit" disabled="@(!CanSubmit)">
        @(_busy ? "Submitting…" : "Open pull request")
    </button>
    @if (!CanSubmit && !_busy)
    {
        <p class="install-hint">@DisabledReason</p>
    }

    @if (_result is not null)
    {
        @if (_result.Success)
        {
            <p class="notice"><span style="color:var(--ok)">✓ Pull request opened:</span> <a href="@_result.PullRequestUrl" target="_blank" rel="noopener">@_result.PullRequestUrl</a></p>
        }
        else
        {
            <p class="notice error">✗ @_result.Error</p>
        }
    }
</section>

@code {
    private string _token = "";
    private string? _authError;
    private bool _busy;

    private string _id = "", _repoUrl = "", _ref = "main";
    private PublishResult? _result;

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        await Auth.RestoreAsync();
    }

    private bool CanSubmit =>
        Auth.IsSignedIn && !_busy && AssetId.IsValid(_id) && !string.IsNullOrWhiteSpace(_repoUrl);

    private string DisabledReason
    {
        get
        {
            if (!Auth.IsSignedIn) return "Sign in with a GitHub token (step 1) to submit.";
            if (!AssetId.IsValid(_id)) return "Enter a valid reverse-DNS id (e.g. com.you.cool-asset).";
            if (string.IsNullOrWhiteSpace(_repoUrl)) return "Enter your asset repo URL.";
            return "";
        }
    }

    private async Task SignIn()
    {
        _busy = true;
        _authError = null;
        try
        {
            if (!await Auth.SignInAsync(_token.Trim()))
            {
                _authError = "Couldn't validate this token. Check it's correct and not expired, and that it can open pull requests (classic `public_repo`, or fine-grained Contents + Pull requests).";
            }
        }
        catch (Exception ex)
        {
            _authError = $"Network error during sign-in: {ex.Message}";
        }
        finally
        {
            _token = "";
            _busy = false;
        }
    }

    private async Task SignOut() => await Auth.SignOutAsync();

    private async Task Submit()
    {
        _busy = true;
        _result = null;

        // Authors often paste the browser URL of the AssetData folder (…/tree/main/AssetData)
        // instead of the clone URL. Normalize it so CI can `git clone`, and lift the ref out of /tree/<ref>.
        var (repo, refFromUrl) = NormalizeRepo(_repoUrl);
        _repoUrl = repo;
        if (refFromUrl is not null && (string.IsNullOrWhiteSpace(_ref) || _ref == "main"))
        {
            _ref = refFromUrl;
        }

        var entry = new RegistryEntry
        {
            Id = _id,
            Repo = repo,
            Latest = new RefPointer { Ref = string.IsNullOrWhiteSpace(_ref) ? "main" : _ref.Trim() },
        };
        _result = await Publisher.PublishAsync(entry);
        _busy = false;
    }

    private static readonly Regex RepoUrlPattern = new(
        @"^(?<repo>https?://github\.com/[^/\s]+/[^/\s]+?)(?:\.git)?(?:/(?:tree|blob)/(?<ref>[^/\s]+)(?:/.*)?)?/?$",
        RegexOptions.Compiled | RegexOptions.IgnoreCase);

    /// <summary>Reduces a pasted GitHub URL to (clone URL, ref?). Strips /tree|/blob, .git and trailing slash.</summary>
    private static (string Repo, string? Ref) NormalizeRepo(string raw)
    {
        var url = raw.Trim();
        var m = RepoUrlPattern.Match(url);
        if (!m.Success)
        {
            return (url, null);
        }

        var refName = m.Groups["ref"].Success ? m.Groups["ref"].Value : null;
        return (m.Groups["repo"].Value, refName);
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Auth.Changed -= OnChanged;
}
